graph {
    graph [rankdir=LR];
    node [label="\N",
        shape=plaintext
    ];
    edge [color=gray50,
        minlen=2,
        style=dashed
    ];
"species" [label=<<FONT FACE="Helvetica"><TABLE BORDER="0" CELLBORDER="1" CELLPADDING="4" CELLSPACING="0"><TR><TD><B><FONT POINT-SIZE="16">species</FONT></B></TD></TR><TR><TD ALIGN="LEFT" PORT="id"><u><FONT>id</FONT></u> <FONT> [UUID]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="created_at"><FONT>created_at</FONT> <FONT> [TIMESTAMP]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="name"><FONT>name</FONT> <FONT> [TEXT]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="notes"><FONT>notes</FONT> <FONT> [TEXT]</FONT></TD></TR><TR><TD ALIGN="LEFT" PORT="ploidy"><FONT>ploidy</FONT> <FONT> [INTEGER]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="updated_at"><FONT>updated_at</FONT> <FONT> [TIMESTAMP]</FONT> NOT NULL</TD></TR></TABLE></FONT>>];
"entries" [label=<<FONT FACE="Helvetica"><TABLE BORDER="0" CELLBORDER="1" CELLPADDING="4" CELLSPACING="0"><TR><TD><B><FONT POINT-SIZE="16">entries</FONT></B></TD></TR><TR><TD ALIGN="LEFT" PORT="id"><u><FONT>id</FONT></u> <FONT> [UUID]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="created_at"><FONT>created_at</FONT> <FONT> [TIMESTAMP]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="entry_type"><FONT>entry_type</FONT> <FONT> [VARCHAR(11)]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="name"><FONT>name</FONT> <FONT> [TEXT]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="notes"><FONT>notes</FONT> <FONT> [TEXT]</FONT></TD></TR><TR><TD ALIGN="LEFT" PORT="species_id"><FONT>species_id</FONT> <FONT> [UUID]</FONT></TD></TR><TR><TD ALIGN="LEFT" PORT="updated_at"><FONT>updated_at</FONT> <FONT> [TIMESTAMP]</FONT> NOT NULL</TD></TR></TABLE></FONT>>];
"entry_relationships" [label=<<FONT FACE="Helvetica"><TABLE BORDER="0" CELLBORDER="1" CELLPADDING="4" CELLSPACING="0"><TR><TD><B><FONT POINT-SIZE="16">entry_relationships</FONT></B></TD></TR><TR><TD ALIGN="LEFT" PORT="id"><u><FONT>id</FONT></u> <FONT> [UUID]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="child_id"><FONT>child_id</FONT> <FONT> [UUID]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="created_at"><FONT>created_at</FONT> <FONT> [TIMESTAMP]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="notes"><FONT>notes</FONT> <FONT> [TEXT]</FONT></TD></TR><TR><TD ALIGN="LEFT" PORT="parent_id"><FONT>parent_id</FONT> <FONT> [UUID]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="rel_type"><FONT>rel_type</FONT> <FONT> [VARCHAR(18)]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="updated_at"><FONT>updated_at</FONT> <FONT> [TIMESTAMP]</FONT> NOT NULL</TD></TR></TABLE></FONT>>];
"experiments" [label=<<FONT FACE="Helvetica"><TABLE BORDER="0" CELLBORDER="1" CELLPADDING="4" CELLSPACING="0"><TR><TD><B><FONT POINT-SIZE="16">experiments</FONT></B></TD></TR><TR><TD ALIGN="LEFT" PORT="id"><u><FONT>id</FONT></u> <FONT> [UUID]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="created_at"><FONT>created_at</FONT> <FONT> [TIMESTAMP]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="end_date"><FONT>end_date</FONT> <FONT> [DATE]</FONT></TD></TR><TR><TD ALIGN="LEFT" PORT="name"><FONT>name</FONT> <FONT> [TEXT]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="notes"><FONT>notes</FONT> <FONT> [TEXT]</FONT></TD></TR><TR><TD ALIGN="LEFT" PORT="start_date"><FONT>start_date</FONT> <FONT> [DATE]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="updated_at"><FONT>updated_at</FONT> <FONT> [TIMESTAMP]</FONT> NOT NULL</TD></TR></TABLE></FONT>>];
"phenotype_data" [label=<<FONT FACE="Helvetica"><TABLE BORDER="0" CELLBORDER="1" CELLPADDING="4" CELLSPACING="0"><TR><TD><B><FONT POINT-SIZE="16">phenotype_data</FONT></B></TD></TR><TR><TD ALIGN="LEFT" PORT="id"><u><FONT>id</FONT></u> <FONT> [UUID]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="created_at"><FONT>created_at</FONT> <FONT> [TIMESTAMP]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="entry_id"><FONT>entry_id</FONT> <FONT> [UUID]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="experiment_id"><FONT>experiment_id</FONT> <FONT> [UUID]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="layout_id"><FONT>layout_id</FONT> <FONT> [UUID]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="measurement_id"><FONT>measurement_id</FONT> <FONT> [UUID]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="site_id"><FONT>site_id</FONT> <FONT> [UUID]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="trait_id"><FONT>trait_id</FONT> <FONT> [UUID]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="treatment_id"><FONT>treatment_id</FONT> <FONT> [UUID]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="updated_at"><FONT>updated_at</FONT> <FONT> [TIMESTAMP]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="value"><FONT>value</FONT> <FONT> [DOUBLE PRECISION]</FONT></TD></TR></TABLE></FONT>>];
"layouts" [label=<<FONT FACE="Helvetica"><TABLE BORDER="0" CELLBORDER="1" CELLPADDING="4" CELLSPACING="0"><TR><TD><B><FONT POINT-SIZE="16">layouts</FONT></B></TD></TR><TR><TD ALIGN="LEFT" PORT="id"><u><FONT>id</FONT></u> <FONT> [UUID]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="block"><FONT>block</FONT> <FONT> [INTEGER]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="col"><FONT>col</FONT> <FONT> [INTEGER]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="created_at"><FONT>created_at</FONT> <FONT> [TIMESTAMP]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="name"><FONT>name</FONT> <FONT> [TEXT]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="replication"><FONT>replication</FONT> <FONT> [INTEGER]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="row"><FONT>row</FONT> <FONT> [INTEGER]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="updated_at"><FONT>updated_at</FONT> <FONT> [TIMESTAMP]</FONT> NOT NULL</TD></TR></TABLE></FONT>>];
"measurements" [label=<<FONT FACE="Helvetica"><TABLE BORDER="0" CELLBORDER="1" CELLPADDING="4" CELLSPACING="0"><TR><TD><B><FONT POINT-SIZE="16">measurements</FONT></B></TD></TR><TR><TD ALIGN="LEFT" PORT="id"><u><FONT>id</FONT></u> <FONT> [UUID]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="created_at"><FONT>created_at</FONT> <FONT> [TIMESTAMP]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="measure_date"><FONT>measure_date</FONT> <FONT> [DATE]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="name"><FONT>name</FONT> <FONT> [TEXT]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="notes"><FONT>notes</FONT> <FONT> [TEXT]</FONT></TD></TR><TR><TD ALIGN="LEFT" PORT="updated_at"><FONT>updated_at</FONT> <FONT> [TIMESTAMP]</FONT> NOT NULL</TD></TR></TABLE></FONT>>];
"sites" [label=<<FONT FACE="Helvetica"><TABLE BORDER="0" CELLBORDER="1" CELLPADDING="4" CELLSPACING="0"><TR><TD><B><FONT POINT-SIZE="16">sites</FONT></B></TD></TR><TR><TD ALIGN="LEFT" PORT="id"><u><FONT>id</FONT></u> <FONT> [UUID]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="created_at"><FONT>created_at</FONT> <FONT> [TIMESTAMP]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="name"><FONT>name</FONT> <FONT> [TEXT]</FONT> NOT NULL</TD></TR><TR><TD ALIGN="LEFT" PORT="notes"><FONT>notes</FONT> <FONT> [TEXT]</FONT></TD></TR><TR><TD ALIGN="LEFT" PORT="updated_at"><FONT>updated_at</FONT> <FONT> [TIMESTAMP]</FONT> NOT NULL</TD></TR></TABLE></FONT>>];
